{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ams.local/schemas/assessment-result.schema.json",
  "title": "Assessment Result",
  "type": "object",
  "required": ["agent", "assessmentId", "summary", "findings", "evidence"],
  "properties": {
    "agent": { "type": "string" },
    "assessmentId": { "type": "string" },
    "summary": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "object" } },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
